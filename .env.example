# Copy to .env and fill in. Keys stay server-side in the proxy — never shipped to the browser.
DEEPGRAM_API_KEY=
TOGETHER_API_KEY=

# Optional
PORT=3000

# Optional — only needed if you swap the LLM to Claude (see AGENTS.md "Swap the LLM provider").
# Point think.apiKeyEnv at ANTHROPIC_API_KEY in config/agent.config.json to use it.
ANTHROPIC_API_KEY=
